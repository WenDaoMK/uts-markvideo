  color: #126fdb;
  font-size: 12px;
  font-weight: 700;
}

.title {
  margin-top: 5px;
  color: #17212b;
  font-size: 24px;
  font-weight: 800;
  line-height: 32px;
}

.hint {
  margin-top: 5px;
  color: #687789;
  font-size: 13px;
  line-height: 20px;
}

.templateList {
  margin-bottom: 14px;
}

.templateCard,
.editor {
  border-width: 1px;
  border-style: solid;
  border-color: #d8e2dc;
  border-radius: 8px;
  background-color: #ffffff;
}

.templateCard {
  margin-bottom: 10px;
  padding: 12px;
}

.selectedCard {
  border-color: #126fdb;
  background-color: #edf5ff;
}

.templatePreview {
  flex-direction: row;
  align-items: center;
}

.templateImage {
  width: 42px;
  height: 42px;
  margin-right: 12px;
  border-radius: 8px;
  background-color: #4d7a39;
}

.templateCopy {
  flex: 1;
}

.templateName,
.editorTitle {
  color: #17212b;
  font-size: 15px;
  font-weight: 700;
  line-height: 22px;
}

.templateText {
  color: #26313b;
  font-size: 14px;
  line-height: 20px;
}

.templateSubtext {
  color: #687789;
  font-size: 12px;
  line-height: 18px;
}

.editor {
  margin-bottom: 16px;
  padding: 14px;
}

.input {
  height: 42px;
  margin-top: 10px;
  padding-left: 12px;
  padding-right: 12px;
  border-width: 1px;
  border-style: solid;
  border-color: #ced9d3;
  border-radius: 8px;
  background-color: #fbfdfc;
  color: #17212b;
  font-size: 14px;
}

.primaryButton,
.secondaryButton {
  border-radius: 8px;
  font-size: 15px;
  font-weight: 700;
}

.primaryButton {
  height: 46px;
  background-color: #126fdb;
  color: #ffffff;
}

.secondaryButton {
  height: 42px;
  margin-top: 10px;
  background-color: #e9f0ed;
  color: #17212b;
}
</style>
