<template>
  <view class="page">
    <view class="header">
      <text class="eyebrow">XYC MarkVideo</text>
      <text class="title">水印相机首页</text>
      <text class="hint">编辑一组默认水印参数，然后进入 cameraX 相机页。</text>
    </view>

    <view class="templateList">
      <view
        v-for="template in templates"
        :key="template.templateId"
        class="templateCard"
        :class="{ selectedCard: selectedTemplateId === template.templateId }"
        @click="selectTemplate(template.templateId)"
      >
        <view class="templatePreview">
          <view v-if="template.templateType === 'image_title_subtitle'" class="templateImage"></view>
          <view class="templateCopy">
            <text class="templateName">{{ template.templateName }}</text>
            <text class="templateText">{{ template.mainTitleText }}</text>
            <text class="templateSubtext">{{ template.subtitleText || '无副标题' }}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="editor">
      <text class="editorTitle">当前模板文字</text>
      <input class="input" v-model="draftMainTitle" maxlength="40" placeholder="主标题" />
      <input class="input" v-model="draftSubtitle" maxlength="80" placeholder="副标题" />
      <button class="secondaryButton" @click="applyDraft">更新当前模板</button>
    </view>

    <button class="primaryButton" @click="openCameraX">进入 cameraX 相机页</button>
  </view>
</template>

<script>
const DEFAULT_TEMPLATES = [
  {
    templateId: 'title-only',
    templateName: '纯主标题',
    templateType: 'title_text',
    mainTitleText: '今日水印相机',
    subtitleText: ''
  },
  {
    templateId: 'title-subtitle',
    templateName: '主副标题',
    templateType: 'title_subtitle_text',
    mainTitleText: '门店巡检',
    subtitleText: '照片和录像共用同一套水印'
  },
  {
    templateId: 'png-title-subtitle',
    templateName: 'PNG 图文',
    templateType: 'image_title_subtitle',
    mainTitleText: '交付留档',
    subtitleText: 'PNG 图片 + 主副标题'
  }
]

export default {
  data() {
    return {
      templates: DEFAULT_TEMPLATES.map((template) => ({ ...template })),
      selectedTemplateId: DEFAULT_TEMPLATES[0].templateId,
      draftMainTitle: DEFAULT_TEMPLATES[0].mainTitleText,
      draftSubtitle: DEFAULT_TEMPLATES[0].subtitleText
    }
  },
  mounted() {
    this.syncCameraPayload()
  },
  methods: {
    currentTemplate() {
      return this.templates.find((template) => template.templateId === this.selectedTemplateId) || this.templates[0]
    },
    selectTemplate(templateId) {
      this.selectedTemplateId = templateId
      const template = this.currentTemplate()
      this.draftMainTitle = template.mainTitleText
      this.draftSubtitle = template.subtitleText
      this.syncCameraPayload()
    },
    applyDraft() {
      const selected = this.currentTemplate()
      selected.mainTitleText = this.draftMainTitle || selected.mainTitleText
      selected.subtitleText = selected.templateType === 'title_text' ? '' : (this.draftSubtitle || selected.subtitleText)
      this.syncCameraPayload()
    },
    syncCameraPayload() {
      uni.setStorageSync('xyc-camera-payload', {
        templates: this.templates,
        selectedTemplateId: this.selectedTemplateId
      })
    },
    openCameraX() {
      this.syncCameraPayload()
      uni.navigateTo({
        url: '/pages/cameraX/index'
      })
    }
  }
}
</script>

